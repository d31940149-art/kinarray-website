---
import SEO from '../components/SEO.astro';
import ContactFloat from '../components/ContactFloat.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  lang: 'en' | 'zh';
  canonicalURL?: string;
  schema?: object;
}

const props = Astro.props;
---

<!DOCTYPE html>
<html lang={props.lang}>
<head>
  <SEO {...props} />
</head>
<body class="min-h-screen bg-white text-gray-900">
  <nav class="bg-white border-b border-gray-200 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between h-16 items-center">
        <a href={`/${props.lang}/`} class="text-2xl font-bold text-blue-600">Kinarray</a>
        <div class="flex gap-6">
          <a href={`/${props.lang}/products/`} class="hover:text-blue-600">{props.lang === 'en' ? 'Products' : '产品'}</a>
          <a href={`/${props.lang}/blog/`} class="hover:text-blue-600">{props.lang === 'en' ? 'Blog' : '博客'}</a>
          <a href={`/${props.lang}/glossary/`} class="hover:text-blue-600">{props.lang === 'en' ? 'Glossary' : '术语库'}</a>
          <a href={props.lang === 'en' ? '/zh/' : '/en/'} class="text-gray-500 hover:text-blue-600">
            {props.lang === 'en' ? '中文' : 'EN'}
          </a>
        </div>
      </div>
    </div>
  </nav>

  <slot />

  <ContactFloat lang={props.lang} />

  <footer class="bg-gray-900 text-white py-12 mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <h3 class="text-xl font-bold mb-4">Kinarray</h3>
          <p class="text-gray-400">
            {props.lang === 'en'
              ? 'Remote non-contact deformation monitoring radar for highways and railways.'
              : '远程非接触式公路铁路边坡形变监测雷达。'}
          </p>
        </div>
        <div>
          <h4 class="font-semibold mb-4">{props.lang === 'en' ? 'Quick Links' : '快速链接'}</h4>
          <ul class="space-y-2 text-gray-400">
            <li><a href={`/${props.lang}/products/`} class="hover:text-white">{props.lang === 'en' ? 'Products' : '产品'}</a></li>
            <li><a href={`/${props.lang}/blog/`} class="hover:text-white">{props.lang === 'en' ? 'Blog' : '博客'}</a></li>
            <li><a href={`/${props.lang}/glossary/`} class="hover:text-white">{props.lang === 'en' ? 'Glossary' : '术语库'}</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold mb-4">{props.lang === 'en' ? 'Contact' : '联系我们'}</h4>
          <p class="text-gray-400">Email: info@kinarray.com</p>
        </div>
      </div>
      <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400">
        <p>&copy; {new Date().getFullYear()} Kinarray. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>
