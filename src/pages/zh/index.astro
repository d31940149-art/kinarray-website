---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'zh';
---

<BaseLayout
  title="Kinarray S500 - 公路地灾专用形变监测雷达"
  description="Kinarray S500 首创数字成像实孔径干涉雷达，专为公路边坡监测设计。亚毫米级精度，7x24小时全天候预警，守护交通生命线。"
  lang={lang}
>
  <style>
    /* Custom Animations */
    @keyframes scan-radar {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    .animate-radar-spin {
      animation: scan-radar 4s linear infinite;
    }
    
    .glass-card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .hero-gradient {
      background: radial-gradient(circle at 50% 0%, #1e293b 0%, #0f172a 100%);
    }

    /* Horizontal scroll for feature strip on mobile */
    .feature-scroll {
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none;  /* IE 10+ */
    }
    .feature-scroll::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }
  </style>

  <main class="bg-slate-50">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex flex-col justify-center hero-gradient overflow-hidden pb-10">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#334155_1px,transparent_1px),linear-gradient(to_bottom,#334155_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-10"></div>
      
      <!-- Glowing Orbs -->
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-600/20 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-orange-500/10 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 pt-32 flex-grow flex items-center">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center w-full">
          <!-- Left Content -->
          <div class="text-left">
            <h2 class="text-blue-400 font-bold text-xl mb-2 tracking-wide uppercase">首创数字成像实孔径干涉雷达</h2>
            <h1 class="text-5xl md:text-6xl font-extrabold text-white tracking-tight mb-6 leading-[1.1]">
              公路地灾专用：<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-100 to-blue-400">S500形变监测雷达</span>
            </h1>
            
            <div class="mb-8">
              <p class="text-2xl text-red-500 font-bold mb-4 animate-pulse">
                专为 7×24 小时长期监测设计
              </p>
              <p class="text-lg text-slate-300 font-medium">
                将公路安全监测技术提升至全新水准！
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-4">
              <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white transition-all duration-300 bg-gradient-to-r from-blue-600 to-blue-700 border border-transparent rounded-xl hover:from-blue-700 hover:to-blue-800 hover:shadow-lg hover:shadow-blue-500/25 hover:-translate-y-1">
                立即咨询
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
              <a href="/zh/products/s500-zh/" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-slate-300 transition-all duration-300 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:text-white hover:border-white/20 backdrop-blur-sm hover:-translate-y-1">
                了解详情
              </a>
            </div>
          </div>

          <!-- Right Radar Visual (Upgraded) -->
          <div class="relative w-full max-w-lg mx-auto lg:ml-auto flex flex-col items-center">
            <div class="aspect-square relative w-full rounded-full border border-slate-700/50 bg-slate-800/30 backdrop-blur-sm p-4 shadow-2xl shadow-blue-900/20 mb-8">
              <!-- Radar Grid -->
              <div class="absolute inset-0 rounded-full border border-slate-700/30 m-12"></div>
              <div class="absolute inset-0 rounded-full border border-slate-700/30 m-24"></div>
              <div class="absolute inset-0 rounded-full border border-slate-700/30 m-36"></div>
              
              <!-- Crosshairs -->
              <div class="absolute top-0 bottom-0 left-1/2 w-px bg-slate-700/30"></div>
              <div class="absolute left-0 right-0 top-1/2 h-px bg-slate-700/30"></div>

              <!-- Scanning Effect -->
              <div class="absolute inset-4 rounded-full overflow-hidden">
                <div class="absolute inset-0 bg-[conic-gradient(from_0deg,transparent_0deg,transparent_270deg,rgba(59,130,246,0.3)_360deg)] animate-radar-spin rounded-full"></div>
              </div>

              <!-- Data Points -->
              <div class="absolute top-1/3 left-1/3 w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_rgba(34,197,94,0.5)]"></div>
              <div class="absolute bottom-1/4 right-1/3 w-2 h-2 bg-orange-500 rounded-full animate-pulse delay-75 shadow-[0_0_10px_rgba(249,115,22,0.5)]"></div>

              <!-- Center Hub -->
              <div class="absolute inset-0 m-auto w-4 h-4 bg-blue-500 rounded-full shadow-[0_0_20px_rgba(59,130,246,0.8)] border-2 border-slate-900"></div>
              
              <!-- Fore Rad Logo Simulation -->
               <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 mt-16 bg-white/10 backdrop-blur-md px-3 py-1 rounded border border-white/20">
                  <span class="text-blue-400 font-bold italic">fore</span><span class="text-slate-300 font-bold italic">rad</span>
               </div>
            </div>
            
            <!-- Dimensions -->
            <div class="text-slate-400 font-mono text-sm tracking-wider bg-slate-800/50 px-4 py-2 rounded-full border border-slate-700">
              S500: 288 × 175 × 47 mm
            </div>
          </div>
        </div>
      </div>

      <!-- Feature Strip (7 Icons) -->
      <div class="w-full mt-16 border-t border-white/10 bg-slate-900/50 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
           <div class="flex overflow-x-auto feature-scroll md:grid md:grid-cols-7 gap-8 pb-4 md:pb-0 min-w-full">
              
              <!-- 1. Large Range -->
              <div class="flex flex-col items-center text-center min-w-[120px]">
                 <div class="w-12 h-12 mb-3 relative">
                    <svg class="w-full h-full text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M13.2 6.5L18 14H22L14.5 3L8 14H3L6 9" fill="currentColor" fill-opacity="0.2" stroke-linejoin="round"/>
                       <path d="M4 18L20 18" stroke="currentColor" stroke-linecap="round"/>
                       <path d="M4 18L7 15M20 18L17 15" stroke="currentColor" stroke-linecap="round"/>
                       <path d="M7 6H17M7 6L9 4M7 6L9 8M17 6L15 4M17 6L15 8" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                 </div>
                 <h3 class="text-blue-400 font-bold text-sm mb-1">大范围覆盖</h3>
                 <p class="text-slate-400 text-[10px] leading-tight">作用距离500m<br/>水平100°覆盖<br/>无盲区监测</p>
              </div>

              <!-- 2. Sub-mm Precision -->
              <div class="flex flex-col items-center text-center min-w-[120px]">
                 <div class="w-12 h-12 mb-3 relative flex items-center justify-center">
                    <svg class="w-full h-full text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M4 12H20" stroke="currentColor" stroke-dasharray="2 2"/>
                       <path d="M12 4V9" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/>
                       <path d="M12 15V20" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/>
                       <path d="M10 9L12 9L14 9" stroke="#ef4444" stroke-width="2"/>
                       <path d="M10 15L12 15L14 15" stroke="#ef4444" stroke-width="2"/>
                    </svg>
                    <span class="absolute text-[10px] font-bold text-white bg-blue-600 px-1 rounded -right-2 top-0">&lt;1mm</span>
                 </div>
                 <h3 class="text-blue-400 font-bold text-sm mb-1">亚毫米精度</h3>
                 <p class="text-slate-400 text-[10px] leading-tight">精度优于1mm<br/>亚毫米级测量<br/>量化变形速率</p>
              </div>

              <!-- 3. All Weather -->
              <div class="flex flex-col items-center text-center min-w-[120px]">
                 <div class="w-12 h-12 mb-3 relative">
                    <svg class="w-full h-full text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M4 14C4 14 2 13 2 9C2 5 6 3 9 5C10 3 14 2 16 5C19 5 21 8 20 11" stroke="currentColor" fill="currentColor" fill-opacity="0.2"/>
                       <path d="M11 12L9 16H13L11 20" stroke="#ef4444" stroke-width="2" stroke-linejoin="round"/>
                       <path d="M16 14V18" stroke="currentColor" stroke-linecap="round"/>
                       <path d="M19 13V16" stroke="currentColor" stroke-linecap="round"/>
                    </svg>
                 </div>
                 <h3 class="text-blue-400 font-bold text-sm mb-1">全天候守护</h3>
                 <p class="text-slate-400 text-[10px] leading-tight">不受天气影响<br/>雨雪雾尘<br/>昼夜连续监测</p>
              </div>

              <!-- 4. Maintenance Free -->
              <div class="flex flex-col items-center text-center min-w-[120px]">
                 <div class="w-12 h-12 mb-3 relative">
                    <svg class="w-full h-full text-orange-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M14.7 6.3L17.7 3.3C18.1 2.9 18.7 2.9 19.1 3.3L20.7 4.9C21.1 5.3 21.1 5.9 20.7 6.3L17.7 9.3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <path d="M3 21L9 15" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <path d="M12.5 11.5L15.5 14.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-opacity="0.3" stroke-dasharray="4 4"/>
                    </svg>
                 </div>
                 <h3 class="text-blue-400 font-bold text-sm mb-1">免维护</h3>
                 <p class="text-slate-400 text-[10px] leading-tight">无需定期校准<br/>模块化设计<br/>坚固耐用</p>
              </div>

              <!-- 5. Low Cost -->
              <div class="flex flex-col items-center text-center min-w-[120px]">
                 <div class="w-12 h-12 mb-3 relative flex items-center justify-center">
                    <svg class="w-full h-full text-blue-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <circle cx="12" cy="12" r="10" stroke="currentColor"/>
                       <path d="M16 16L12 12M12 12L8 8M12 12L16 8M12 12L8 16" stroke="currentColor" stroke-opacity="0.2"/>
                       <path d="M9 8L15 8M9 12H15M12 8V16" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/> 
                    </svg>
                 </div>
                 <h3 class="text-blue-400 font-bold text-sm mb-1">低成本</h3>
                 <p class="text-slate-400 text-[10px] leading-tight">部署成本低<br/>易安装<br/>人力减少</p>
              </div>

              <!-- 6. Low Power -->
              <div class="flex flex-col items-center text-center min-w-[120px]">
                 <div class="w-12 h-12 mb-3 relative">
                    <svg class="w-full h-full text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-opacity="0.3"/>
                       <path d="M12 18V12L14 8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <path d="M12 12L10 16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <path d="M12 6V4" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/>
                       <path d="M12 12C12 12 8 10 8 7C8 5 9.5 3.5 11.5 3.5C13.5 3.5 15 5 15 7" fill="currentColor" fill-opacity="0.2" stroke="none"/>
                    </svg>
                 </div>
                 <h3 class="text-blue-400 font-bold text-sm mb-1">超低功耗</h3>
                 <p class="text-slate-400 text-[10px] leading-tight">功耗≤15W<br/>可太阳能供电<br/>阴雨天持续工作</p>
              </div>

               <!-- 7. Auto Warning -->
              <div class="flex flex-col items-center text-center min-w-[120px]">
                 <div class="w-12 h-12 mb-3 relative">
                    <svg class="w-full h-full text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M12 3V5M5.6 5.6L7 7M18.4 5.6L17 7" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/>
                       <path d="M12 8C9 8 7 10 7 14V17H17V14C17 10 15 8 12 8Z" fill="currentColor" fill-opacity="0.2" stroke="currentColor"/>
                       <path d="M5 17H19" stroke="currentColor" stroke-linecap="round"/>
                       <path d="M10 20C10 21.1046 10.8954 22 12 22C13.1046 22 14 21.1046 14 20" stroke="currentColor" stroke-linecap="round"/>
                    </svg>
                 </div>
                 <h3 class="text-blue-400 font-bold text-sm mb-1">自动预警</h3>
                 <p class="text-slate-400 text-[10px] leading-tight">内置报警模块<br/>平台联动<br/>实时报警提示</p>
              </div>

           </div>
        </div>
      </div>
    </section>

    <!-- Hazard Context Section -->
    <section class="py-24 bg-white relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
          <div class="order-2 lg:order-1 relative">
             <div class="aspect-[4/3] rounded-3xl bg-slate-100 overflow-hidden relative shadow-2xl transform rotate-1 border-4 border-white">
                <img src="/hazard-context.png" alt="公路边坡灾害示意图" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-900/90 via-slate-900/50 to-transparent p-8 pt-20">
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-10 bg-orange-500 rounded-full"></div>
                    <div>
                      <div class="text-white font-bold text-xl">不可预测的风险</div>
                      <div class="text-slate-300 text-sm">需要 24/7 的技术防线</div>
                    </div>
                  </div>
                </div>
             </div>
             <!-- Decorative blob -->
             <div class="absolute -z-10 -bottom-10 -left-10 w-full h-full bg-slate-100 rounded-3xl -rotate-2"></div>
          </div>

          <div class="order-1 lg:order-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-50 text-orange-600 font-bold text-xs uppercase tracking-wider mb-6 border border-orange-100">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              严峻挑战
            </div>
            <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-8 leading-tight">
              边坡灾害：<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-red-500">无法承受的痛</span>
            </h2>
            <p class="text-lg text-slate-600 mb-8 leading-relaxed">
              公路沿线地质环境复杂，滑坡、崩塌等地质灾害突发性强。传统的“人防”模式难以做到全天候监控，一旦发生灾害，往往造成交通瘫痪、巨额抢修成本，甚至危及过往车辆和人员安全。
            </p>
            <div class="grid grid-cols-2 gap-6">
              <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100">
                <div class="text-4xl font-extrabold text-slate-900 mb-1">40<span class="text-xl text-slate-500">%</span></div>
                <div class="text-sm text-slate-500 font-medium">突发性地质灾害占比</div>
              </div>
              <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100">
                <div class="text-4xl font-extrabold text-orange-500 mb-1">$$$</div>
                <div class="text-sm text-slate-500 font-medium">巨大的应急抢险成本</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Specs Section -->
    <section class="py-24 bg-slate-900 text-white relative overflow-hidden">
      <!-- Decorator -->
      <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-blue-900/20 to-transparent pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <div>
            <h2 class="text-4xl font-extrabold mb-6">工业级可靠性参数</h2>
            <p class="text-slate-400 mb-12 text-lg">
              每一个参数都经过严苛测试，确保在最恶劣的野外环境中依然稳定运行。
            </p>
            
            <div class="grid grid-cols-2 gap-4">
              <div class="p-6 rounded-2xl bg-slate-800/50 border border-slate-700 backdrop-blur-sm">
                <div class="text-sm text-slate-400 mb-2">工作温度</div>
                <div class="text-2xl font-mono font-bold text-white">-40°C ~ +65°C</div>
              </div>
              <div class="p-6 rounded-2xl bg-slate-800/50 border border-slate-700 backdrop-blur-sm">
                <div class="text-sm text-slate-400 mb-2">防护等级</div>
                <div class="text-2xl font-mono font-bold text-white">IP65 / IP67</div>
              </div>
              <div class="p-6 rounded-2xl bg-slate-800/50 border border-slate-700 backdrop-blur-sm">
                <div class="text-sm text-slate-400 mb-2">系统重量</div>
                <div class="text-2xl font-mono font-bold text-white">&lt; 5 KG</div>
              </div>
              <div class="p-6 rounded-2xl bg-slate-800/50 border border-slate-700 backdrop-blur-sm">
                <div class="text-sm text-slate-400 mb-2">功耗</div>
                <div class="text-2xl font-mono font-bold text-white">&lt; 15 W</div>
              </div>
            </div>
          </div>
          
          <div class="relative flex items-center justify-center">
            <div class="absolute inset-0 bg-blue-600/20 blur-[80px] rounded-full"></div>
            <!-- Abstract visualization of robust technology -->
            <div class="relative z-10 w-full max-w-md bg-slate-800/80 backdrop-blur-md border border-slate-700 rounded-3xl p-8 shadow-2xl">
               <div class="space-y-6">
                 <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                   <span class="text-slate-400">测量原理</span>
                   <span class="font-bold text-blue-400">地基干涉合成孔径雷达</span>
                 </div>
                 <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                   <span class="text-slate-400">数据更新率</span>
                   <span class="font-bold text-white">秒级实时</span>
                 </div>
                 <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                   <span class="text-slate-400">通讯方式</span>
                   <span class="font-bold text-white">4G / 5G / 光纤</span>
                 </div>
                 <div class="flex items-center justify-between">
                   <span class="text-slate-400">供电方式</span>
                   <span class="font-bold text-white">市电 / 太阳能</span>
                 </div>
               </div>
               
               <div class="mt-8 pt-8 border-t border-slate-700">
                 <a href="/zh/products/s500-zh/" class="flex items-center justify-between w-full p-4 bg-blue-600 hover:bg-blue-500 rounded-xl transition-all group shadow-lg shadow-blue-600/25">
                   <span class="font-bold">下载完整技术手册</span>
                   <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                 </a>
               </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-24 bg-white" id="contact">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl font-extrabold text-slate-900 mb-6">准备好提升基础设施安全等级了吗？</h2>
        <p class="text-xl text-slate-500 mb-10">
          联系 Kinarray 专家团队，获取针对您项目的定制化监测方案。
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="mailto:info@foresens.com" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white transition-all duration-200 bg-orange-500 border border-transparent rounded-xl hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 shadow-xl shadow-orange-500/20 hover:-translate-y-1">
            联系我们
          </a>
          <a href="/zh/blog/" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-blue-600 transition-all duration-200 bg-blue-50 border border-blue-100 rounded-xl hover:bg-blue-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 hover:-translate-y-1">
            浏览技术博客
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>