---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'en';
---

<BaseLayout
  title="Kinarray S500 - Critical Slope Safety Guardian"
  description="Kinarray S500 designed for critical slope monitoring. Sub-millimeter accuracy, 24/7 early warning, zero-target non-contact measurement. Safeguarding critical infrastructure."
  lang={lang}
>
  <style>
    /* Custom Animations */
    @keyframes scan-line {
      0% { left: -10%; opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { left: 110%; opacity: 0; }
    }
    .animate-scan-line {
      animation: scan-line 3s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }
    
    .glass-card {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .hero-gradient {
      background: radial-gradient(circle at 50% 0%, #1e293b 0%, #0f172a 100%);
    }

    /* Horizontal scroll for feature strip on mobile */
    .feature-scroll {
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none;  /* IE 10+ */
    }
    .feature-scroll::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }
  </style>

  <main class="bg-slate-50">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex flex-col justify-center hero-gradient overflow-hidden pb-10">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#334155_1px,transparent_1px),linear-gradient(to_bottom,#334155_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-10"></div>
      
      <!-- Glowing Orbs -->
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-600/20 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-orange-500/10 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 pt-32 flex-grow flex items-center">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center w-full">
          <!-- Left Content -->
          <div class="text-left">
            <h2 class="text-blue-400 font-bold text-xl mb-2 tracking-wide uppercase">Pioneering Digital Imaging Real Aperture Interferometric Radar</h2>
            <h1 class="text-5xl md:text-6xl font-extrabold text-white tracking-tight mb-6 leading-[1.1]">
              Critical Slope Safety Specialist:<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-100 to-blue-400">S500 Deformation Radar</span>
            </h1>
            
            <div class="mb-8">
              <p class="text-2xl text-orange-500 font-bold mb-4 animate-pulse">
                Designed for 7×24 Long-term Monitoring
              </p>
              <p class="text-lg text-slate-300 font-medium">
                Elevating Slope Safety Monitoring to a New Level!
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-4">
              <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white transition-all duration-300 bg-gradient-to-r from-blue-600 to-blue-700 border border-transparent rounded-xl hover:from-blue-700 hover:to-blue-800 hover:shadow-lg hover:shadow-blue-500/25 hover:-translate-y-1">
                Consult Now
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
              <a href="/en/products/s500-en/" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-slate-300 transition-all duration-300 bg-white/5 border border-white/10 rounded-xl hover:bg-white/10 hover:text-white hover:border-white/20 backdrop-blur-sm hover:-translate-y-1">
                View Specs
              </a>
            </div>
          </div>

          <!-- Right Radar Visual (Solid State) -->
          <div class="relative w-full max-w-lg mx-auto lg:ml-auto flex flex-col items-center">
            <div class="relative w-full aspect-square bg-slate-900/50 rounded-3xl border border-slate-700/50 backdrop-blur-sm p-8 shadow-2xl shadow-blue-900/20 mb-8 overflow-hidden group">
              <!-- Tech Grid Background -->
              <div class="absolute inset-0 bg-[linear-gradient(rgba(59,130,246,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.05)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
              
              <!-- Digital Array Matrix (Center) -->
              <div class="absolute inset-0 flex items-center justify-center">
                 <div class="w-64 h-44 bg-slate-800 rounded-xl border border-slate-600 relative overflow-hidden shadow-[0_0_60px_rgba(59,130,246,0.15)]">
                    <!-- Array Dots -->
                    <div class="grid grid-cols-12 gap-1 p-2 h-full w-full opacity-50">
                       {Array.from({ length: 96 }).map((_, i) => (
                         <div class="bg-blue-400 rounded-full w-full h-full opacity-20"></div>
                       ))}
                    </div>
                    
                    <!-- Active Elements (Randomly lit) -->
                    <div class="absolute inset-0 grid grid-cols-12 gap-1 p-2 h-full w-full">
                       <div class="col-start-2 row-start-3 bg-blue-400 rounded-full w-full h-full shadow-[0_0_4px_#60a5fa] animate-pulse"></div>
                       <div class="col-start-8 row-start-5 bg-blue-400 rounded-full w-full h-full shadow-[0_0_4px_#60a5fa] animate-pulse delay-75"></div>
                       <div class="col-start-5 row-start-2 bg-blue-400 rounded-full w-full h-full shadow-[0_0_4px_#60a5fa] animate-pulse delay-150"></div>
                       <div class="col-start-10 row-start-6 bg-blue-400 rounded-full w-full h-full shadow-[0_0_4px_#60a5fa] animate-pulse delay-300"></div>
                    </div>

                    <!-- Electronic Beam Scan (Vertical Bar moving across) -->
                    <div class="absolute top-0 bottom-0 w-2 bg-gradient-to-r from-transparent via-blue-400/50 to-transparent blur-sm animate-scan-line"></div>
                 </div>
              </div>

              <!-- Digital Wavefronts (Emitting from array) -->
              <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                 <div class="w-80 h-80 border border-blue-500/10 rounded-full animate-ping [animation-duration:3s]"></div>
                 <div class="w-80 h-80 border border-blue-500/10 rounded-full animate-ping [animation-duration:3s] [animation-delay:1s]"></div>
              </div>

              <!-- HUD Overlay -->
              <div class="absolute top-6 left-6 flex flex-col gap-1">
                 <div class="flex items-center gap-2">
                    <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                    <span class="text-xs font-mono text-blue-300 tracking-wider">SOLID STATE ARRAY</span>
                 </div>
                 <span class="text-[10px] font-mono text-slate-500">MIMO ACTIVE</span>
              </div>

              <div class="absolute bottom-6 right-6 text-right">
                 <div class="text-[10px] font-mono text-slate-500">UPDATE RATE</div>
                 <div class="text-lg font-mono text-white font-bold">2s / Scan</div>
              </div>
            </div>
            
            <!-- Dimensions -->
            <div class="text-slate-400 font-mono text-sm tracking-wider bg-slate-800/50 px-4 py-2 rounded-full border border-slate-700">
              S500: 288 × 175 × 47 mm
            </div>
          </div>
        </div>
      </div>

      <!-- Feature Strip (6 Icons) -->
      <div class="w-full mt-16 border-t border-white/10 bg-slate-900/50 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
           <div class="flex md:grid md:grid-cols-3 overflow-x-auto feature-scroll gap-8 pb-4 md:pb-0 md:gap-y-12 md:gap-x-8">
              
              <!-- 1. Large Range -->
              <div class="flex flex-col items-center text-center group">
                 <div class="w-32 h-32 mb-6 relative p-6 rounded-3xl bg-blue-500/10 border border-blue-500/20 group-hover:border-blue-500/50 transition-colors">
                    <svg class="w-full h-full text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M13.2 6.5L18 14H22L14.5 3L8 14H3L6 9" fill="currentColor" fill-opacity="0.2" stroke-linejoin="round"/>
                       <path d="M4 18L20 18" stroke="currentColor" stroke-linecap="round"/>
                       <path d="M4 18L7 15M20 18L17 15" stroke="currentColor" stroke-linecap="round"/>
                       <path d="M7 6H17M7 6L9 4M7 6L9 8M17 6L15 4M17 6L15 8" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                 </div>
                 <h3 class="text-white font-bold text-lg mb-2">Wide Area Coverage</h3>
                 <ul class="text-slate-400 text-sm space-y-1">
                    <li>Range 500m</li>
                    <li>100° FOV</li>
                    <li>No Blind Spots</li>
                 </ul>
              </div>

              <!-- 2. Sub-mm Precision -->
              <div class="flex flex-col items-center text-center group">
                 <div class="w-32 h-32 mb-6 relative p-6 rounded-3xl bg-blue-500/10 border border-blue-500/20 group-hover:border-blue-500/50 transition-colors flex items-center justify-center">
                    <svg class="w-full h-full text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M4 12H20" stroke="currentColor" stroke-dasharray="2 2"/>
                       <path d="M12 4V9" stroke="#f97316" stroke-width="2" stroke-linecap="round"/>
                       <path d="M12 15V20" stroke="#f97316" stroke-width="2" stroke-linecap="round"/>
                       <path d="M10 9L12 9L14 9" stroke="#f97316" stroke-width="2"/>
                       <path d="M10 15L12 15L14 15" stroke="#f97316" stroke-width="2"/>
                    </svg>
                    <span class="absolute -top-3 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg border border-blue-400">&lt;1mm</span>
                 </div>
                 <h3 class="text-white font-bold text-lg mb-2">Sub-mm Precision</h3>
                 <ul class="text-slate-400 text-sm space-y-1">
                    <li>Accuracy &lt; 1mm</li>
                    <li>Quantifiable Rate</li>
                    <li>High Precision</li>
                 </ul>
              </div>

              <!-- 3. All Weather -->
              <div class="flex flex-col items-center text-center group">
                 <div class="w-32 h-32 mb-6 relative p-6 rounded-3xl bg-blue-500/10 border border-blue-500/20 group-hover:border-blue-500/50 transition-colors">
                    <svg class="w-full h-full text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M4 14C4 14 2 13 2 9C2 5 6 3 9 5C10 3 14 2 16 5C19 5 21 8 20 11" stroke="currentColor" fill="currentColor" fill-opacity="0.2"/>
                       <path d="M11 12L9 16H13L11 20" stroke="#f97316" stroke-width="2" stroke-linejoin="round"/>
                       <path d="M16 14V18" stroke="currentColor" stroke-linecap="round"/>
                       <path d="M19 13V16" stroke="currentColor" stroke-linecap="round"/>
                    </svg>
                 </div>
                 <h3 class="text-white font-bold text-lg mb-2">All-weather Guard</h3>
                 <ul class="text-slate-400 text-sm space-y-1">
                    <li>Weather Proof</li>
                    <li>Rain/Snow/Fog</li>
                    <li>24/7 Monitoring</li>
                 </ul>
              </div>

              <!-- 4. Maintenance Free -->
              <div class="flex flex-col items-center text-center group">
                 <div class="w-32 h-32 mb-6 relative p-6 rounded-3xl bg-blue-500/10 border border-blue-500/20 group-hover:border-blue-500/50 transition-colors">
                    <svg class="w-full h-full text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M14.7 6.3L17.7 3.3C18.1 2.9 18.7 2.9 19.1 3.3L20.7 4.9C21.1 5.3 21.1 5.9 20.7 6.3L17.7 9.3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <path d="M3 21L9 15" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <path d="M12.5 11.5L15.5 14.5" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-opacity="0.3" stroke-dasharray="4 4"/>
                    </svg>
                 </div>
                 <h3 class="text-white font-bold text-lg mb-2">Maintenance Free</h3>
                 <ul class="text-slate-400 text-sm space-y-1">
                    <li>No Calibration</li>
                    <li>Modular Design</li>
                    <li>Rugged Build</li>
                 </ul>
              </div>

              <!-- 5. Low Power -->
              <div class="flex flex-col items-center text-center group">
                 <div class="w-32 h-32 mb-6 relative p-6 rounded-3xl bg-blue-500/10 border border-blue-500/20 group-hover:border-blue-500/50 transition-colors">
                    <svg class="w-full h-full text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-opacity="0.3"/>
                       <path d="M12 18V12L14 8" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <path d="M12 12L10 16" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
                       <path d="M12 6V4" stroke="#f97316" stroke-width="2" stroke-linecap="round"/>
                       <path d="M12 12C12 12 8 10 8 7C8 5 9.5 3.5 11.5 3.5C13.5 3.5 15 5 15 7" fill="currentColor" fill-opacity="0.2" stroke="none"/>
                    </svg>
                 </div>
                 <h3 class="text-white font-bold text-lg mb-2">Ultra-low Power</h3>
                 <ul class="text-slate-400 text-sm space-y-1">
                    <li>Peak Power 15W</li>
                    <li>Sleep Mode 0.1W</li>
                    <li>Solar Power Ready</li>
                 </ul>
              </div>

               <!-- 6. Auto Warning -->
              <div class="flex flex-col items-center text-center group">
                 <div class="w-32 h-32 mb-6 relative p-6 rounded-3xl bg-blue-500/10 border border-blue-500/20 group-hover:border-blue-500/50 transition-colors">
                    <svg class="w-full h-full text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                       <path d="M12 3V5M5.6 5.6L7 7M18.4 5.6L17 7" stroke="#f97316" stroke-width="2" stroke-linecap="round"/>
                       <path d="M12 8C9 8 7 10 7 14V17H17V14C17 10 15 8 12 8Z" fill="currentColor" fill-opacity="0.2" stroke="currentColor"/>
                       <path d="M5 17H19" stroke="currentColor" stroke-linecap="round"/>
                       <path d="M10 20C10 21.1046 10.8954 22 12 22C13.1046 22 14 21.1046 14 20" stroke="currentColor" stroke-linecap="round"/>
                    </svg>
                 </div>
                 <h3 class="text-white font-bold text-lg mb-2">Auto Warning</h3>
                 <ul class="text-slate-400 text-sm space-y-1">
                    <li>Built-in Alarm</li>
                    <li>Platform Link</li>
                    <li>Real-time Alert</li>
                 </ul>
              </div>

           </div>
        </div>
      </div>
      
      <!-- Gradient Separator -->
      <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-b from-transparent to-slate-50 pointer-events-none"></div>
    </section>

    <!-- Hazard Context Section -->
    <section class="pb-24 pt-12 bg-slate-50 relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
          <div class="order-2 lg:order-1 relative">
             <div class="aspect-[4/3] rounded-3xl bg-slate-100 overflow-hidden relative shadow-2xl transform rotate-1 border-4 border-white">
                <img src="/hazard-context.png" alt="Landslide Hazard Illustration" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" />
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-900/90 via-slate-900/50 to-transparent p-8 pt-20">
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-10 bg-orange-500 rounded-full"></div>
                    <div>
                      <div class="text-white font-bold text-xl">Unpredictable Risks</div>
                      <div class="text-slate-300 text-sm">Need 24/7 Technical Defense</div>
                    </div>
                  </div>
                </div>
             </div>
             <!-- Decorative blob -->
             <div class="absolute -z-10 -bottom-10 -left-10 w-full h-full bg-white rounded-3xl -rotate-2"></div>
          </div>

          <div class="order-1 lg:order-2">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-50 text-orange-600 font-bold text-xs uppercase tracking-wider mb-6 border border-orange-100">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              Critical Challenge
            </div>
            <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-8 leading-tight">
              Slope Hazards:<br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-600 to-red-500">Unbearable Cost</span>
            </h2>
            <p class="text-lg text-slate-600 mb-8 leading-relaxed">
              Geological environments along critical infrastructure corridors and natural slopes are complex, with sudden landslides and collapses. Traditional "manual monitoring" fails to provide 24/7 coverage. 
            </p>
            
            <!-- Key Challenges List -->
            <div class="space-y-4">
              <div class="flex items-start gap-4 p-4 bg-white rounded-xl border border-slate-200 shadow-sm">
                <div class="mt-1 w-8 h-8 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 text-red-600">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900">Sudden & Unpredictable</h4>
                  <p class="text-sm text-slate-500 mt-1">Disasters often occur at night or during extreme weather, making manual detection impossible.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-4 p-4 bg-white rounded-xl border border-slate-200 shadow-sm">
                <div class="mt-1 w-8 h-8 rounded-full bg-orange-100 flex items-center justify-center flex-shrink-0 text-orange-600">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900">High Economic Impact</h4>
                  <p class="text-sm text-slate-500 mt-1">Road closures and emergency repairs cause massive economic losses and traffic paralysis.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Specs Section -->
    <section class="py-24 bg-slate-900 text-white relative overflow-hidden">
      <!-- Decorator -->
      <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-blue-900/20 to-transparent pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <div>
            <h2 class="text-4xl font-extrabold mb-6">Industrial Grade Reliability</h2>
            <p class="text-slate-400 mb-12 text-lg">
              Every parameter is rigorously tested to ensure stable operation in the harshest outdoor environments.
            </p>
            
            <div class="grid grid-cols-2 gap-4">
              <div class="p-6 rounded-2xl bg-slate-800/50 border border-slate-700 backdrop-blur-sm">
                <div class="text-sm text-slate-400 mb-2">Operating Temp</div>
                <div class="text-2xl font-mono font-bold text-white">-40°C ~ +65°C</div>
              </div>
              <div class="p-6 rounded-2xl bg-slate-800/50 border border-slate-700 backdrop-blur-sm">
                <div class="text-sm text-slate-400 mb-2">Protection</div>
                <div class="text-2xl font-mono font-bold text-white">IP65 / IP67</div>
              </div>
              <div class="p-6 rounded-2xl bg-slate-800/50 border border-slate-700 backdrop-blur-sm">
                <div class="text-sm text-slate-400 mb-2">System Weight</div>
                <div class="text-2xl font-mono font-bold text-white">&lt; 5 KG</div>
              </div>
              <div class="p-6 rounded-2xl bg-slate-800/50 border border-slate-700 backdrop-blur-sm">
                <div class="text-sm text-slate-400 mb-2">Power Consumption</div>
                <div class="text-2xl font-mono font-bold text-white">&lt; 15 W</div>
              </div>
            </div>
          </div>
          
          <div class="relative flex items-center justify-center">
            <div class="absolute inset-0 bg-blue-600/20 blur-[80px] rounded-full"></div>
            <!-- Abstract visualization of robust technology -->
            <div class="relative z-10 w-full max-w-md bg-slate-800/80 backdrop-blur-md border border-slate-700 rounded-3xl p-8 shadow-2xl">
               <div class="space-y-6">
                 <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                   <span class="text-slate-400">Principle</span>
                   <span class="font-bold text-blue-400">GB-InSAR</span>
                 </div>
                 <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                   <span class="text-slate-400">Update Rate</span>
                   <span class="font-bold text-white">Real-time (Seconds)</span>
                 </div>
                 <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                   <span class="text-slate-400">Communication</span>
                   <span class="font-bold text-white">4G / 5G / Fiber</span>
                 </div>
                 <div class="flex items-center justify-between">
                   <span class="text-slate-400">Power Supply</span>
                   <span class="font-bold text-white">Mains / Solar</span>
                 </div>
               </div>
               
               <div class="mt-8 pt-8 border-t border-slate-700">
                 <a href="/en/products/s500-en/" class="flex items-center justify-between w-full p-4 bg-blue-600 hover:bg-blue-500 rounded-xl transition-all group shadow-lg shadow-blue-600/25">
                   <span class="font-bold">Download Tech Manual</span>
                   <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                 </a>
               </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-24 bg-white" id="contact">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl font-extrabold text-slate-900 mb-6">Ready to Upgrade Safety Standards?</h2>
        <p class="text-xl text-slate-500 mb-10">
