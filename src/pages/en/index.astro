---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'en';
---

<BaseLayout
  title="Kinarray - Deformation Monitoring Radar for Highway & Railway Safety"
  description="Remote non-contact deformation monitoring radar with millimeter-level accuracy for highway and railway slope safety. 24/7 real-time early warning system."
  lang={lang}
>
  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-blue-600 to-blue-800 text-white py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-5xl font-bold mb-6">
            Protect Your Infrastructure with<br />Advanced Radar Monitoring
          </h1>
          <p class="text-xl mb-8 text-blue-100 max-w-3xl mx-auto">
            Remote, non-contact deformation monitoring for highways and railways.
            Millimeter-level accuracy. Real-time early warning. 24/7 unattended operation.
          </p>
          <div class="flex gap-4 justify-center">
            <a href="/en/products/" class="bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
              View Products
            </a>
            <a href="/en/blog/" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-blue-600 transition">
              Learn More
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center mb-12">Why Choose Kinarray?</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center p-6">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Remote & Safe</h3>
            <p class="text-gray-600">No need to access dangerous slopes. Monitor from a safe distance.</p>
          </div>
          <div class="text-center p-6">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Real-Time Alerts</h3>
            <p class="text-gray-600">Instant notifications via phone and WeChat when deformation is detected.</p>
          </div>
          <div class="text-center p-6">
            <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <h3 class="text-xl font-semibold mb-2">Millimeter Accuracy</h3>
            <p class="text-gray-600">Detect movements as small as 0.1mm with advanced radar technology.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Product Highlight -->
    <section class="bg-gray-50 py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-bold mb-6">Kinarray S500</h2>
            <p class="text-lg text-gray-600 mb-6">
              Highway disaster prevention deformation monitoring radar designed for 24/7 unattended operation in harsh environments.
            </p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>500m monitoring range with 0.1-1mm accuracy</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>Wide temperature range: -40°C to +65°C</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>Compact and lightweight: only 3kg</span>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span>Solar powered with battery backup</span>
              </li>
            </ul>
            <a href="/en/products/s500-en/" class="inline-block bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
              Learn More
            </a>
          </div>
          <div class="bg-gray-200 rounded-lg h-96 flex items-center justify-center">
            <span class="text-gray-500">Product Image Placeholder</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-blue-600 text-white py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold mb-4">Ready to Protect Your Infrastructure?</h2>
        <p class="text-xl mb-8 text-blue-100">
          Contact us today to learn how Kinarray can help secure your highways and railways.
        </p>
        <a href="mailto:info@kinarray.com" class="inline-block bg-white text-blue-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
          Get in Touch
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
