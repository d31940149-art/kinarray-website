---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'en';
---

<BaseLayout
  title="Kinarray S500 - Highway Slope Safety Guardian"
  description="Kinarray S500 designed for highway slope monitoring. Sub-millimeter accuracy, 24/7 early warning, zero-target non-contact measurement. Safeguarding critical infrastructure."
  lang={lang}
>
  <style>
    /* Custom Animations */
    @keyframes scan {
      0% { transform: translateY(-100%); opacity: 0; }
      50% { opacity: 1; }
      100% { transform: translateY(100%); opacity: 0; }
    }
    .animate-scan {
      animation: scan 3s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }
    
    .glass-card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
  </style>

  <main class="bg-white">
    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center bg-slate-900 overflow-hidden">
      <!-- Background Effects -->
      <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-20"></div>
      <div class="absolute inset-0 bg-slate-900/50"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 pt-20">
        <div class="text-center max-w-4xl mx-auto mb-16">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-900/30 border border-blue-500/30 text-blue-400 font-mono text-sm mb-8 animate-fade-in">
            <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
            Kinarray S500 System Ready
          </div>
          <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight mb-8 leading-tight">
            Highway Slope<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-blue-200 to-white">Safety Guardian</span>
          </h1>
          <p class="text-xl text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed">
            Designed for complex geological environments. Capturing 0.1mm micro-deformation to identify landslide risks early.
            <span class="text-orange-500 font-semibold">Protecting every mile of transportation safety.</span>
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white transition-all duration-200 bg-orange-500 border border-transparent rounded-xl hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 shadow-lg shadow-orange-500/30 hover:-translate-y-1">
              Request Consultation
            </a>
            <a href="/en/products/s500-en/" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white transition-all duration-200 bg-transparent border-2 border-slate-600 rounded-xl hover:bg-slate-800 hover:border-slate-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-slate-500 hover:-translate-y-1">
              View Specs
            </a>
          </div>
        </div>

        <!-- Radar Visual -->
        <div class="relative max-w-5xl mx-auto mt-12">
          <div class="aspect-[16/9] bg-slate-800 rounded-t-3xl border border-slate-700 overflow-hidden relative shadow-2xl">
             <div class="absolute inset-0 bg-gradient-to-b from-blue-500/5 to-transparent"></div>
             <!-- Simulated Radar UI -->
             <div class="absolute inset-0 p-8 flex items-end justify-between">
                <div class="space-y-2">
                  <div class="flex items-center gap-2 text-xs font-mono text-slate-500">
                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                    SYSTEM ONLINE
                  </div>
                  <div class="text-4xl font-mono font-bold text-slate-200">0.00<span class="text-sm text-slate-500">mm</span></div>
                  <div class="text-xs text-slate-500">Displacement</div>
                </div>
                
                <!-- Scanning Line -->
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-full bg-gradient-to-b from-transparent via-orange-500/50 to-transparent animate-scan"></div>
                
                <div class="grid grid-cols-3 gap-8">
                   <div>
                     <div class="text-xs text-slate-500 mb-1">Range</div>
                     <div class="font-mono text-blue-400">500 M</div>
                   </div>
                   <div>
                     <div class="text-xs text-slate-500 mb-1">Frequency</div>
                     <div class="font-mono text-blue-400">100 Hz</div>
                   </div>
                   <div>
                     <div class="text-xs text-slate-500 mb-1">Status</div>
                     <div class="font-mono text-green-500">NORMAL</div>
                   </div>
                </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Hazard Context Section -->
    <section class="py-24 bg-slate-50 relative overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-100 text-orange-600 font-semibold text-xs uppercase tracking-wider mb-6">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              Critical Challenge
            </div>
            <h2 class="text-4xl font-extrabold text-slate-900 mb-6 leading-tight">
              Slope Hazards:<br/>
              <span class="text-orange-600">Unbearable Cost of Life & Economy</span>
            </h2>
            <p class="text-lg text-slate-600 mb-8 leading-relaxed">
              Geological environments along highways are complex, with sudden landslides and collapses. Traditional "manual monitoring" fails to provide 24/7 coverage. Once disaster strikes, it causes traffic paralysis, huge repair costs, and endangers lives.
            </p>
            <div class="grid grid-cols-2 gap-6">
              <div class="p-6 bg-white rounded-2xl shadow-sm border border-slate-100">
                <div class="text-3xl font-extrabold text-slate-900 mb-1">40<span class="text-lg text-slate-500">%</span></div>
                <div class="text-sm text-slate-500">Sudden Geo-Disasters</div>
              </div>
              <div class="p-6 bg-white rounded-2xl shadow-sm border border-slate-100">
                <div class="text-3xl font-extrabold text-orange-500 mb-1">$$$</div>
                <div class="text-sm text-slate-500">Massive Emergency Costs</div>
              </div>
            </div>
          </div>
          <div class="relative">
             <div class="aspect-square rounded-3xl bg-slate-200 overflow-hidden relative shadow-lg">
                <img src="/hazard-context.png" alt="Landslide Hazard Illustration" class="w-full h-full object-cover" />
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-900/90 to-transparent p-8">
                  <div class="text-white font-bold text-lg">Unpredictable Risks</div>
                  <div class="text-slate-300 text-sm">Need 24/7 Technical Defense</div>
                </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Capabilities Section -->
    <section class="py-24 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto mb-20">
          <h2 class="text-4xl font-extrabold text-slate-900 mb-4">S500 Core Capabilities</h2>
          <p class="text-xl text-slate-500">Redefining monitoring standards, making safety accessible.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <!-- Card 1 -->
          <div class="group p-8 rounded-2xl bg-white border border-slate-100 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-6 group-hover:bg-blue-600 transition-colors duration-300">
              <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">Sub-mm Early Warning</h3>
            <p class="text-slate-500 leading-relaxed text-sm">
              Capable of capturing <span class="text-orange-500 font-bold">0.1mm</span> micro-deformations, issuing alerts hours or days before disaster strikes.
            </p>
          </div>

          <!-- Card 2 -->
          <div class="group p-8 rounded-2xl bg-white border border-slate-100 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-6 group-hover:bg-blue-600 transition-colors duration-300">
              <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">24/7 Harsh Env Duty</h3>
            <p class="text-slate-500 leading-relaxed text-sm">
              Designed for extreme weather (-40°C to +65°C), rain/snow resistant, fully automated all-weather monitoring without human presence.
            </p>
          </div>

          <!-- Card 3 -->
          <div class="group p-8 rounded-2xl bg-white border border-slate-100 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-6 group-hover:bg-blue-600 transition-colors duration-300">
              <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">Zero Targets Required</h3>
            <p class="text-slate-500 leading-relaxed text-sm">
              Non-contact measurement, <span class="text-blue-600 font-bold">no need to install prisms on dangerous slopes</span>. Plug-and-play, minimizing installation risk.
            </p>
          </div>

          <!-- Card 4 -->
          <div class="group p-8 rounded-2xl bg-white border border-slate-100 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="w-14 h-14 rounded-xl bg-blue-50 flex items-center justify-center mb-6 group-hover:bg-blue-600 transition-colors duration-300">
              <svg class="w-8 h-8 text-blue-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">Wide Area Coverage</h3>
            <p class="text-slate-500 leading-relaxed text-sm">
              Single unit covers <span class="text-blue-600 font-bold">500m</span> radius with 100° horizontal field of view, achieving true wide-area monitoring.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Specs Section -->
    <section class="py-24 bg-slate-900 text-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <div>
            <h2 class="text-4xl font-extrabold mb-6">Industrial Grade Reliability</h2>
            <p class="text-slate-400 mb-12 text-lg">
              Every parameter is rigorously tested to ensure stable operation in the harshest outdoor environments.
            </p>
            
            <div class="grid grid-cols-2 gap-4">
              <div class="p-6 rounded-2xl bg-slate-800 border border-slate-700">
                <div class="text-sm text-slate-400 mb-2">Operating Temp</div>
                <div class="text-2xl font-mono font-bold text-white">-40°C ~ +65°C</div>
              </div>
              <div class="p-6 rounded-2xl bg-slate-800 border border-slate-700">
                <div class="text-sm text-slate-400 mb-2">Protection</div>
                <div class="text-2xl font-mono font-bold text-white">IP65 / IP67</div>
              </div>
              <div class="p-6 rounded-2xl bg-slate-800 border border-slate-700">
                <div class="text-sm text-slate-400 mb-2">System Weight</div>
                <div class="text-2xl font-mono font-bold text-white">&lt; 5 KG</div>
              </div>
              <div class="p-6 rounded-2xl bg-slate-800 border border-slate-700">
                <div class="text-sm text-slate-400 mb-2">Power Consumption</div>
                <div class="text-2xl font-mono font-bold text-white">&lt; 20 W</div>
              </div>
            </div>
          </div>
          
          <div class="relative flex items-center justify-center">
            <div class="absolute inset-0 bg-blue-600/20 blur-3xl rounded-full"></div>
            <!-- Abstract visualization of robust technology -->
            <div class="relative z-10 w-full max-w-md bg-slate-800/50 backdrop-blur-sm border border-slate-700 rounded-3xl p-8">
               <div class="space-y-6">
                 <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                   <span class="text-slate-400">Principle</span>
                   <span class="font-bold text-blue-400">GB-InSAR</span>
                 </div>
                 <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                   <span class="text-slate-400">Update Rate</span>
                   <span class="font-bold text-white">Real-time (Seconds)</span>
                 </div>
                 <div class="flex items-center justify-between border-b border-slate-700 pb-4">
                   <span class="text-slate-400">Communication</span>
                   <span class="font-bold text-white">4G / 5G / Fiber</span>
                 </div>
                 <div class="flex items-center justify-between">
                   <span class="text-slate-400">Power Supply</span>
                   <span class="font-bold text-white">Mains / Solar</span>
                 </div>
               </div>
               
               <div class="mt-8 pt-8 border-t border-slate-700">
                 <a href="/en/products/s500-en/" class="flex items-center justify-between w-full p-4 bg-blue-600 hover:bg-blue-500 rounded-xl transition-colors group">
                   <span class="font-bold">Download Tech Manual</span>
                   <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                 </a>
               </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-24 bg-white" id="contact">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-4xl font-extrabold text-slate-900 mb-6">Ready to Upgrade Safety Standards?</h2>
        <p class="text-xl text-slate-500 mb-10">
          Contact Kinarray experts for a customized monitoring solution for your project.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="mailto:info@foresens.com" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white transition-all duration-200 bg-orange-500 border border-transparent rounded-xl hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 shadow-xl shadow-orange-500/20 hover:-translate-y-1">
            Contact Us
          </a>
          <a href="/en/blog/" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-blue-600 transition-all duration-200 bg-blue-50 border border-blue-100 rounded-xl hover:bg-blue-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 hover:-translate-y-1">
            Technical Blog
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>