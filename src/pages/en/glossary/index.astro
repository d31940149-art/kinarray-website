---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'en';
const terms = await getCollection('glossary', ({ data }) => data.lang === lang);

// Group terms by first letter
const groupedTerms = terms.reduce((acc, term) => {
  const firstLetter = term.data.term[0].toUpperCase();
  if (!acc[firstLetter]) acc[firstLetter] = [];
  acc[firstLetter].push(term);
  return acc;
}, {} as Record<string, typeof terms>);

// Sort each group
Object.keys(groupedTerms).forEach(letter => {
  groupedTerms[letter].sort((a, b) => a.data.term.localeCompare(b.data.term));
});

const sortedLetters = Object.keys(groupedTerms).sort();

// Pre-render terms to avoid async in template
const renderedTerms = await Promise.all(
  sortedLetters.map(async (letter) => {
    const terms = groupedTerms[letter];
    const rendered = await Promise.all(
      terms.map(async (term) => {
        const { Content } = await term.render();
        return { term, Content };
      })
    );
    return { letter, terms: rendered };
  })
);
---

<BaseLayout
  title="Glossary - Deformation Monitoring Terms | Kinarray"
  description="Comprehensive glossary of technical terms related to deformation monitoring, radar technology, and infrastructure safety."
  lang={lang}
>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold mb-4">Technical Glossary</h1>
    <p class="text-gray-600 mb-8">
      Key terms and definitions related to deformation monitoring and radar technology.
    </p>

    <!-- Alphabet Navigation -->
    <div class="flex flex-wrap gap-2 mb-8 pb-8 border-b border-gray-200">
      {sortedLetters.map(letter => (
        <a
          href={`#${letter}`}
          class="w-10 h-10 flex items-center justify-center bg-blue-100 text-blue-600 rounded hover:bg-blue-200 transition font-semibold"
        >
          {letter}
        </a>
      ))}
    </div>

    <!-- Terms by Letter -->
    {renderedTerms.map(({ letter, terms }) => (
      <section id={letter} class="mb-16">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-4xl font-bold text-slate-200">{letter}</h2>
          <div class="h-px bg-slate-200 flex-grow"></div>
        </div>
        
        <div class="space-y-12">
          {terms.map(({ term, Content }) => (
              <article class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden hover:shadow-md transition-shadow duration-300">
                <div class="p-8">
                  <div class="flex items-start justify-between mb-4">
                     <h3 class="text-2xl font-bold text-slate-900 flex items-center gap-3">
                       <div class="w-2 h-8 bg-blue-600 rounded-full"></div>
                       {term.data.term}
                     </h3>
                     <span class="px-3 py-1 bg-slate-100 text-slate-500 text-xs font-mono rounded-full uppercase tracking-wider">Term</span>
                  </div>
                  
                  <p class="text-lg text-slate-600 mb-8 italic border-l-4 border-slate-100 pl-4 py-2 bg-slate-50/50 rounded-r-lg">
                    {term.data.definition}
                  </p>
                  
                  <div class="prose prose-slate max-w-none prose-headings:font-bold prose-headings:text-slate-800 prose-a:text-blue-600 hover:prose-a:text-blue-500">
                    <Content />
                  </div>
    
                  {term.data.relatedArticles && term.data.relatedArticles.length > 0 && (
                    <div class="mt-8 pt-6 border-t border-slate-100">
                      <span class="text-sm font-bold text-slate-400 uppercase tracking-wider block mb-3">Related Reading</span>
                      <div class="flex flex-wrap gap-3">
                        {term.data.relatedArticles.map((slug, i) => (
                          <a href={`/en/blog/${slug}/`} class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-blue-50 text-blue-700 text-sm hover:bg-blue-100 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                            {slug}
                          </a>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </article>
          ))}
        </div>
      </section>
    ))}
  </main>
</BaseLayout>
